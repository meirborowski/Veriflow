# PostgreSQL
POSTGRES_USER=veriflow
POSTGRES_PASSWORD=veriflow_dev
POSTGRES_DB=veriflow

# Server
DATABASE_URL=postgresql://veriflow:veriflow_dev@db:5432/veriflow
PORT=3001
CLIENT_URL=http://localhost:3000

# Auth (Phase 1)
JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=veriflow
MINIO_ROOT_PASSWORD=veriflow_dev
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=veriflow
MINIO_SECRET_KEY=veriflow_dev
MINIO_BUCKET=veriflow-attachments
MINIO_USE_SSL=false

# Redis (Phase 6 — Automation)
REDIS_HOST=redis
REDIS_PORT=6379

# Automation (Phase 6)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-32-byte-hex-encryption-key-64-chars
WORKER_API_KEY=change-me-worker-api-key

# Worker service (Phase 6b)
VERIFLOW_API_URL=http://server:3001/api/v1
WORKER_CONCURRENCY=2
MAX_RUN_DURATION_MS=600000
